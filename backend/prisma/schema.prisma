generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String            @id @default(uuid())
  email               String            @unique
  phone               String?           @unique
  password            String
  firstName           String
  lastName            String
  avatar              String?
  role                UserRole          @default(STUDENT)
  status              AccountStatus     @default(ACTIVE)
  isEmailVerified     Boolean           @default(false)
  isPhoneVerified     Boolean           @default(false)
  onboardingCompleted Boolean           @default(false)
  preferredExamType   String?
  preferredSubjects   String[]
  points              Int               @default(0)
  level               Int               @default(1)
  streak              Int               @default(0)
  lastActive          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  notifications       Notification[]
  progress            Progress[]
  promoUsages         PromoCodeUsage[]  @relation("PromoSubscriber")
  promoCodes          PromoCode[]       @relation("PromoCodeOwner")
  quizAttempts        QuizAttempt[]
  studySessions       StudySession[]
  subscription        Subscription?
  achievements        UserAchievement[]

  @@index([email])
  @@index([phone])
  @@map("users")
}

model Subscription {
  id           String             @id @default(uuid())
  userId       String             @unique
  plan         SubscriptionPlan   @default(FREE)
  status       SubscriptionStatus @default(ACTIVE)
  startDate    DateTime           @default(now())
  endDate      DateTime?
  autoRenew    Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model Transaction {
  id             String            @id @default(uuid())
  subscriptionId String
  amount         Float
  currency       String            @default("XOF")
  provider       PaymentProvider
  transactionId  String?           @unique
  phoneNumber    String?
  status         TransactionStatus @default(PENDING)
  failureReason  String?
  metadata       Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  promoCodeUsage PromoCodeUsage?
  subscription   Subscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([transactionId])
  @@index([status])
  @@map("transactions")
}

model PromoCode {
  id        String           @id @default(uuid())
  code      String           @unique
  ownerId   String
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  usages    PromoCodeUsage[]
  owner     User             @relation("PromoCodeOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("promo_codes")
}

model PromoCodeUsage {
  id               String         @id @default(uuid())
  promoCodeId      String
  subscriberId     String
  transactionId    String         @unique
  commissionAmount Float
  type             CommissionType
  createdAt        DateTime       @default(now())
  promoCode        PromoCode      @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  subscriber       User           @relation("PromoSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  transaction      Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
  @@index([subscriberId])
  @@map("promo_code_usages")
}

model Exam {
  id             String          @id @default(uuid())
  title          String
  type           String
  year           Int?
  subject        String
  description    String?
  pdfUrl         String?
  thumbnailUrl   String?
  difficulty     DifficultyLevel @default(MEDIUM)
  duration       Int?
  totalQuestions Int             @default(0)
  downloadCount  Int             @default(0)
  viewCount      Int             @default(0)
  tags           String[]
  isPublished    Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  faculty        String?
  university     String?         @default("NONE")
  series         String?
  niveau         String?
  questions      Question[]

  @@index([type])
  @@index([subject])
  @@index([year])
  @@index([series])
  @@index([university])
  @@index([faculty])
  @@map("exams")
}

model Question {
  id            String          @id @default(uuid())
  examId        String
  content       String
  type          QuestionType    @default(MULTIPLE_CHOICE)
  options       Json?
  correctAnswer String?
  explanation   String?
  difficulty    DifficultyLevel @default(MEDIUM)
  imageUrl      String?
  timesAnswered Int             @default(0)
  timesCorrect  Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  exam          Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([difficulty])
  @@map("questions")
}

model Quiz {
  id             String          @id @default(uuid())
  title          String
  description    String?
  subject        String
  mode           QuizMode        @default(PRACTICE)
  timeLimit      Int?
  passingScore   Float?
  questionIds    String[]
  totalQuestions Int
  difficulty     DifficultyLevel @default(MEDIUM)
  totalAttempts  Int             @default(0)
  averageScore   Float?
  isPublished    Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  attempts       QuizAttempt[]

  @@index([subject])
  @@index([mode])
  @@map("quizzes")
}

model QuizAttempt {
  id               String    @id @default(uuid())
  userId           String
  quizId           String
  score            Float
  totalQuestions   Int
  correctAnswers   Int
  wrongAnswers     Int
  skippedQuestions Int       @default(0)
  timeSpent        Int
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  answers          Json
  isPassed         Boolean   @default(false)
  rank             Int?
  createdAt        DateTime  @default(now())
  quiz             Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@index([score])
  @@map("quiz_attempts")
}

model Progress {
  id             String    @id @default(uuid())
  userId         String
  subject        String
  examType       String
  totalQuizzes   Int       @default(0)
  totalQuestions Int       @default(0)
  correctAnswers Int       @default(0)
  averageScore   Float     @default(0)
  totalTimeSpent Int       @default(0)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastStudyDate  DateTime?
  weakAreas      Json?
  strongAreas    Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject, examType])
  @@index([userId])
  @@map("progress")
}

model Achievement {
  id          String            @id @default(uuid())
  name        String
  description String
  type        AchievementType
  iconUrl     String?
  requirement Json
  points      Int               @default(0)
  createdAt   DateTime          @default(now())
  users       UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model StudySession {
  id                String    @id @default(uuid())
  userId            String
  subject           String
  examType          String
  startTime         DateTime  @default(now())
  endTime           DateTime?
  duration          Int?
  quizzesCompleted  Int       @default(0)
  questionsAnswered Int       @default(0)
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("study_sessions")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  actionUrl String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model ExamConfig {
  id          String   @id @default(uuid())
  category    String
  value       String
  label       String
  description String?
  extra       Json?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, value])
  @@index([category])
  @@map("exam_configs")
}

enum UserRole {
  STUDENT
  ADMIN
  MODERATOR
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SubscriptionPlan {
  FREE
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MTN_MONEY
  MOOV_MONEY
  ORANGE_MONEY
  STRIPE
  PAYPAL
  WAVE
}

enum CommissionType {
  FIRST_TIME
  RENEWAL
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
}

enum QuizMode {
  PRACTICE
  TIMED
  COMPETITIVE
  ADAPTIVE
}

enum AchievementType {
  STREAK
  SCORE
  QUIZ_COUNT
  TIME_SPENT
  PERFECT_SCORE
  MILESTONE
}

enum NotificationType {
  SYSTEM
  SUBSCRIPTION
  ACHIEVEMENT
  REMINDER
  SOCIAL
}
